# ============================================================
# LangGraph 推荐系统 — 环境变量配置
# ============================================================

# ── LLM API Keys（至少配置一个）──
# 阿里云百炼平台 (DashScope) — 默认
DASHSCOPE_API_KEY=sk- 
DASHSCOPE_BASE_URL= 

# OpenAI 兼容
OPENAI_API_KEY=sk- 
OPENAI_BASE_URL= 

# DeepSeek
DEEPSEEK_API_KEY=sk- 
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1



# ── HuggingFace 镜像（国内网络加速）──
# 如果无法访问 huggingface.co，取消下面这行注释
HF_ENDPOINT=https://hf-mirror.com

# ── Redis 缓存（可选）──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# RESP 协议: 3=Redis≥6.0,  2=Redis<6.0（报 HELLO 错误时改为 2）
REDIS_PROTOCOL=2
# 缓存过期时间（秒）
CACHE_TTL=3600

# ── 数据库（电影/用户/评分）──
# DB_TYPE: mysql (默认) 或 sqlite（零配置本地开发）
DB_TYPE=mysql
# MySQL 连接（DB_TYPE=mysql 时生效）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=      
DB_NAME=recommender
# SQLite 文件路径（DB_TYPE=sqlite 时生效）
SQLITE_PATH=recommender.db

# ── SQLite 数据库（长期记忆 / 交互历史）──
DB_PATH=recommender_memory.db

# ── FAISS 索引目录 ──
FAISS_INDEX_DIR=.faiss_index

# ── 服务配置 ──
HOST=127.0.0.1
PORT=8000
